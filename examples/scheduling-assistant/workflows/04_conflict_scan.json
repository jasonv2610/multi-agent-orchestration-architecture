                            "name": "nextWorkflow",
                            "value": "06_notify",
                            "type": "string"
                        },
                        {
                            "id": "notification-type-conflict",
                            "name": "notificationType",
                            "value": "conflict_detected",
                            "type": "string"
                        }
                    ]
                },
                "options": {}
            },
            "id": "set-conflict-output",
            "name": "Set Conflict Output",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.2,
            "position": [
                1050,
                400
            ]
        },
        {
