    "---\n",
    "## Section 4 - Confidence Gate Simulation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "confidence-gate",
   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(42)\n",
    "n = 500\n",
    "scores = np.concatenate([\n",
    "    np.random.beta(6, 2, int(n * 0.82)) * 0.40 + 0.60,\n",
    "    np.random.uniform(0.30, 0.69, int(n * 0.18)),\n",
    "])\n",
    "scores = np.clip(scores, 0, 1)\n",
    "threshold = 0.70\n",
    "routed, clarified = scores[scores >= threshold], scores[scores < threshold]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "ax.hist(routed,    bins=25, color='#e94560', alpha=0.85, label=f'Routed \\u2265 {threshold} ({len(routed)/n:.0%})')\n",
    "ax.hist(clarified, bins=10, color='#4a90d9', alpha=0.85, label=f'Clarification < {threshold} ({len(clarified)/n:.0%})')\n",
    "ax.axvline(threshold, color='#ffcc00', linewidth=1.8, linestyle='--', label=f'Threshold ({threshold})')\n",
    "ax.set_xlabel('Confidence Score')\n",
    "ax.set_ylabel('Request Count')\n",
    "ax.set_title('LLM Classification Confidence Distribution (n=500)', color='white', fontsize=12)\n",
    "ax.legend(fontsize=10)\n",
    "ax.grid(axis='y')\n",
    "plt.tight_layout()\n",
    "plt.savefig('confidence_distribution.png', dpi=150, bbox_inches='tight', facecolor='#0f0f0f', edgecolor='none')\n",
    "plt.show()\n",
    "print(f'Routed: {len(routed)} ({len(routed)/n:.0%}) | Clarification: {len(clarified)} ({len(clarified)/n:.0%})')"
   ]
